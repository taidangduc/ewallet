{
    "Routes": 
    [      
        {
            "UpstreamPathTemplate": "/api/Authentication/{everything}",
            "UpstreamHttpMethod": [ "Get" ],
            "DownstreamScheme": "http",
            "DownstreamPathTemplate": "/api/Authentication/{everything}",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 6002
                }
            ],
            "AuthenticationOptions":{
                "AuthenticationProviderKey":"Bearer"
            }
        },
        {
            "UpstreamPathTemplate": "/api/Authentication/{everything}",
            "UpstreamHttpMethod": [ "Post" ],
            "DownstreamScheme": "http",
            "DownstreamPathTemplate": "/api/Authentication/{everything}",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 6002
                }
            ]
        },
        {
            "UpstreamPathTemplate": "/api/Wallet/{everything}",
            "UpstreamHttpMethod": [ "Get", "Post" ],
            "DownstreamScheme": "http",
            "DownstreamPathTemplate": "/api/Wallet/{everything}",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 6001
                }
            ],
            "AuthenticationOptions": {
                "AuthenticationProviderKey": "Bearer",
                "AllowedScopes": ["write", "read", "all"]
            }    
        },
        {
            "UpstreamPathTemplate": "/api/Transaction/{everything}",
            "UpstreamHttpMethod": [ "Get", "Post" ],
            "DownstreamScheme": "http",
            "DownstreamPathTemplate": "/api/Transaction/{everything}",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 6001
                }
            ],
            "AuthenticationOptions": {
                "AuthenticationProviderKey": "Bearer",
                "AllowedScopes": ["write", "read", "all"]
            }    
        }
    ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:6000"
    }
}