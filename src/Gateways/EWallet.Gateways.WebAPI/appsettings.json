{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CORS": {
    "AllowAnyOrigin": true,
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Jwt": {
    "SecretKey": "a-string-secret-at-least-256-bits-long",
    "Authority": "https://localhost:5002",
    "Audience": "ewallet-api",
    "ExpiredTime": 60
  },
  "Yarp": {
    "Routes": {
      "Identity":{
        "ClusterId": "Identity",
        "Match": {
          "Path": "/api/Authentication/{**catch-all}"
        }
      },
      "Wallet":{
        "ClusterId": "Wallet",
        "Match": {
          "Path": "/api/Wallet/{**catch-all}"
        }
      },
      "Transaction":{
        "ClusterId": "Transaction",
        "Match": {
          "Path": "/api/Transaction/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "Identity": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:7002/"
          }
        }
      },
      "Wallet": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:7001/"
          }
        }
       },
      "Transaction": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:7001/"
          }
        }
      }
    }
  }
}